{
  "name": "fish",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "pnpm --filter @fish/web dev",
    "dev:web": "pnpm --filter @fish/web dev",
    "build": "pnpm -r --if-present build",
    "build:web": "pnpm --filter @fish/web build",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "supabase:start": "supabase start",
    "db:reset": "supabase db reset",
    "seed": "node --experimental-strip-types --env-file=apps/web/.env.local scripts/seed.ts",
    "verify:rls": "node --experimental-strip-types --env-file=apps/web/.env.local scripts/verify-rls.ts"
  },
  "devDependencies": {
    "next": "16.2.9",
    "typescript": "5.7.3",
    "@supabase/supabase-js": "2.110.0"
  }
}
