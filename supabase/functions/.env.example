# Use devkey / secret with `livekit-server --dev` locally.
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
# Store the complete JSON as one quoted Edge Function secret in staging/production.
FCM_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"fish-project","client_email":"firebase-adminsdk@example.iam.gserviceaccount.com","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"}'
LESSON_JOIN_WINDOW_MINUTES=10
FRIENDS_ENABLED=false
# Required before enabling document attachments. The scanner must return an
# explicit clean/malicious verdict; missing or unavailable scanners fail closed.
CHAT_ATTACHMENT_SCANNER_URL=https://scanner.example.com/scan
CHAT_ATTACHMENT_SCANNER_TOKEN=replace-with-scanner-bearer-token
# Use an independent random value of at least 32 characters, and store the same
# value through configure_chat_attachment_cleanup after deploying migrations.
CHAT_ATTACHMENT_CLEANUP_SECRET=replace-with-32-plus-random-characters
