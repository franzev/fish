# Local Supabase (run `supabase start`, then `supabase status` to read values)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Local sign-in convenience. These server-only values prefill the sign-in form
# outside production and are ignored when NODE_ENV=production.
DEV_LOGIN_EMAIL=client1@fish.dev
DEV_LOGIN_PASSWORD=fish-client-dev

# How many minutes before a scheduled lesson the Join action becomes available.
# Keep this value in sync with supabase/functions/.env.local in development and
# the call-command Edge Function secret in deployed environments.
LESSON_JOIN_WINDOW_MINUTES=10

# Google OAuth provider credentials used by Supabase Auth. The Google auth
# actions stay hidden unless both values are present.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# Server-side friends rollout switch. The local seed command synchronizes the
# authoritative database gate to this value; the friend Edge Function has a
# matching switch in supabase/functions/.env.local.
FRIENDS_ENABLED=false

# Server-side opt-in for avatar mutations. Keep false until the Edge Function
# and private Storage bucket have been verified in the target environment.
AVATAR_UPLOADS_ENABLED=false

# Public integration identifier used by the browser-only KLIPY GIF picker.
# Restrict this key to the FISH web origins in the KLIPY partner dashboard.
NEXT_PUBLIC_KLIPY_API_KEY=
NEXT_PUBLIC_KLIPY_CLIENT_KEY=fish_chat

# Error monitoring is opt-in per deployment. Keep disabled locally and in
# production. Set all five variables only in Vercel Preview and the dedicated
# staging environment. The auth token is a build secret used for source maps.
NEXT_PUBLIC_SENTRY_ENABLED=false
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Seed script only — NEVER expose with a NEXT_PUBLIC_ prefix, never commit a real value
SUPABASE_SERVICE_ROLE_KEY=
