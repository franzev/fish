[
  {
    "name": "hydrateUnreadFeed",
    "events": [{ "type": "hydrate" }],
    "expected": { "itemIds": ["action", "direct"], "unreadCount": 2, "needsRefresh": false }
  },
  {
    "name": "markAllReadSnapshot",
    "events": [
      { "type": "hydrate" },
      { "type": "optimisticOperation", "operationKind": "markAllRead", "throughChangeSeq": 10 }
